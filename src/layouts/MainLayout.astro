---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title} | Unique International</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@100..800&display=swap"
      rel="stylesheet"
    />

    <!-- SEO tags -->
    <meta name="title" content="Panther Electric Vehicles" />
    <meta
      name="description"
      content="Revolutionizing commercial transport in India with sustainable, durable, and cost-effective electric rickshaws."
    />

    <!-- OG tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://pantherev.com/" />
    <meta
      property="og:title"
      content="Panther Electric Vehicles - The Future of Mobility"
    />
    <meta
      property="og:description"
      content="Engineering high-performance e-rickshaws for Indian roads."
    />
    <meta property="og:image" content="/favicon.ico" />

    <!-- Extra tags -->
    <link rel="canonical" href="https://pantherev.com/" />
  </head>
  <body>
    <slot />
  </body>
</html>
