---
// components/Features.astro
---

<section id="features" class="relative py-24 bg-background text-text">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Heading -->
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight">
        Built for Performance. Designed for Earnings.
      </h2>
      <p class="mt-4 text-muted text-sm sm:text-base">
        Every part of Panther is engineered to deliver reliability, efficiency,
        and long-term value on the road.
      </p>
    </div>

    <!-- Grid -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Card -->
      {[
        {
          title: "High Mileage Efficiency",
          desc: "Drive longer on a single charge and maximize daily earnings.",
        },
        {
          title: "Heavy Load Capacity",
          desc: "Built strong to carry more passengers and goods with ease.",
        },
        {
          title: "Low Maintenance",
          desc: "Engineered for fewer breakdowns and lower running costs.",
        },
        {
          title: "Durable Build Quality",
          desc: "Strong chassis designed for Indian roads and long-term use.",
        },
        {
          title: "Comfortable Ride",
          desc: "Smooth suspension ensures better experience for driver and passengers.",
        },
        {
          title: "Proven Reliability",
          desc: "Trusted across India for over 10 years in real conditions.",
        },
      ].map((item) => (
        <div class="group rounded-xl border border-border bg-surface/50 p-6 hover:bg-surface transition-all duration-300 hover:shadow-[0_0_25px_rgba(24,204,252,0.15)]">

          <!-- Icon -->
          <div class="mb-4 h-10 w-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
            <!-- Simple SVG icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>

          <!-- Title -->
          <h3 class="text-lg font-semibold">
            {item.title}
          </h3>

          <!-- Description -->
          <p class="mt-2 text-sm text-muted leading-relaxed">
            {item.desc}
          </p>

        </div>
      ))}

    </div>
  </div>
</section>
