---
import { Phone, Mail, MapPin } from "lucide-astro";
---

<section id="contact" class="relative py-24 bg-background text-text">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Heading -->
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight">
        Get in Touch
      </h2>
      <p class="mt-4 text-muted text-sm sm:text-base">
        Interested in Panther E-Rickshaw or dealership opportunities? Fill the
        form and our team will get back to you shortly.
      </p>
    </div>

    <!-- Content -->
    <div class="mt-16 grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
      <!-- LEFT: Info -->
      <div class="space-y-8">
        <!-- CTA Box -->
        <div class="rounded-xl border border-border bg-surface/50 p-6">
          <h3 class="text-xl font-semibold">Become a Dealer</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">
            Join our growing network and expand your business with a trusted and
            high-demand electric vehicle.
          </p>

          <ul class="mt-4 space-y-2 text-sm text-muted">
            <li>✔ High demand product</li>
            <li>✔ Reliable supply</li>
            <li>✔ Strong market trust</li>
          </ul>
        </div>

        <!-- Contact Info -->
        <div class="space-y-4 text-sm">
          <div class="flex items-center gap-3 text-muted">
            <Phone class="h-5 w-5 text-primary" />
            <span>+91 - 7900678600</span>
          </div>

          <div class="flex items-center gap-3 text-muted">
            <Mail class="h-5 w-5 text-primary" />
            <span>panthererickshaw@gmail.com</span>
          </div>

          <div class="flex items-center gap-3 text-muted">
            <MapPin class="h-5 w-5 text-primary" />
            <span>
              164, Mohkampur, Near Amar Ujala, Meerut, Uttar Pradesh - 250002
            </span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Form -->
      <div class="rounded-xl border border-border bg-surface/50 p-6">
        <form class="space-y-5">
          <!-- Name -->
          <div>
            <label class="text-sm text-muted">Full Name</label>
            <input
              type="text"
              required
              placeholder="Enter your name"
              class="mt-2 w-full rounded-lg border border-border bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40"
            />
          </div>

          <!-- Phone -->
          <div>
            <label class="text-sm text-muted">Mobile Number</label>
            <input
              type="tel"
              required
              placeholder="Enter your mobile number"
              class="mt-2 w-full rounded-lg border border-border bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40"
            />
          </div>

          <!-- Email -->
          <div>
            <label class="text-sm text-muted">Email Address</label>
            <input
              type="email"
              required
              placeholder="Enter your email"
              class="mt-2 w-full rounded-lg border border-border bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40"
            />
          </div>

          <!-- Interest -->
          <div>
            <label class="text-sm text-muted">I'm Interested In</label>
            <select
              class="mt-2 w-full rounded-lg border border-border bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40"
            >
              <option>Buying E-Rickshaw</option>
              <option>Dealership</option>
              <option>Bulk Purchase</option>
              <option>Other</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label class="text-sm text-muted">Message</label>
            <textarea
              rows="4"
              placeholder="Tell us your requirement..."
              class="mt-2 w-full rounded-lg border border-border bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full rounded-lg bg-primary px-6 py-3 text-sm font-medium text-black hover:bg-primaryDark transition-all duration-300 shadow-[0_0_25px_rgba(24,204,252,0.3)]"
          >
            Submit Inquiry
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector("form") as HTMLFormElement;
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    form.reset();
  });
</script>
