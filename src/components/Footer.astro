---
import { Phone, Mail, MapPin, Facebook, Instagram, Youtube } from "lucide-astro";

const products = [
  "Panther Deluxe",
  "Panther Super Deluxe",
  "Panther Cargo",
  "Panther XL",
  "Panther XL Cargo",
  "Panther XL+",
  "Panther L5",
];

const links = [
  { name: "Home", href: "#" },
  { name: "Features", href: "#features" },
  { name: "Why Choose Us", href: "#why" },
  { name: "Products", href: "#products" },
  { name: "Contact", href: "#contact" },
];
---

<footer class="relative bg-background text-text border-t border-border">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Column 1: Brand -->
      <div>
        <img src="/logo.svg" alt="Panther Logo" class="mb-4" />

        <p class="text-sm">
          Revolutionizing commercial transport in India with sustainable, durable, and cost-effective electric rickshaws. Engineering the future of eco-friendly last-mile mobility.
        </p>

        <!-- Social Links -->
        <div class="mt-5 flex items-center gap-4">
          <a
            href="https://www.facebook.com/panther.e.rickshaw/"
            target="_blank"
            class="p-2 rounded-lg bg-surface hover:bg-primary/10 text-muted hover:text-primary transition-all duration-300"
          >
            <Facebook class="size-6" />
          </a>

          <a
            href="https://www.instagram.com/panthererickshaw?igsh=emlxdHF5b213cnF3"
            target="_blank"
            class="p-2 rounded-lg bg-surface hover:bg-primary/10 text-muted hover:text-primary transition-all duration-300"
          >
            <Instagram class="size-6" />
          </a>

          <a
            href="https://youtube.com/@panthererickshaw9264?si=_2ELtVAXiP_vJnkE"
            target="_blank"
            class="p-2 rounded-lg bg-surface hover:bg-primary/10 text-muted hover:text-primary transition-all duration-300"
          >
            <Youtube class="size-6" />
          </a>
        </div>
      </div>

      <!-- Column 2: Products -->
      <div>
        <h4 class="text-sm font-semibold mb-4">Our Vehicles</h4>

        <ul class="space-y-2">
          {products.map((item) => (
            <li>
              <a
                href="#products"
                class="group flex items-center justify-between rounded-lg px-3 py-2 text-sm text-muted hover:text-text hover:bg-surface hover:shadow-[0_0_15px_rgba(24,204,252,0.15)] transition-all duration-300"
              >
                <span>{item}</span>

                <!-- Arrow -->
                <span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-primary">
                  →
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Navigation -->
      <div>
        <h4 class="text-sm font-semibold mb-4">Quick Links</h4>

        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="group flex items-center justify-between rounded-lg px-3 py-2 text-sm text-muted hover:text-text hover:bg-surface hover:shadow-[0_0_15px_rgba(24,204,252,0.15)] transition-all duration-300"
              >
                <span>{link.name}</span>

                <!-- Arrow -->
                <span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-primary">
                  →
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 class="text-sm font-semibold mb-4">Contact</h4>

        <div class="space-y-6 text-sm text-muted">
          <div class="flex items-center gap-3">
            <Phone class="size-4 text-primary" />
            <span>+91 - 7900678600</span>
          </div>

          <div class="flex items-center gap-3">
            <Mail class="size-4 text-primary" />
            <span>panthererickshaw@gmail.com</span>
          </div>

          <div class="flex items-start gap-3">
            <MapPin class="size-8 text-primary" />
            <span>
              164, Mohkampur, Near Amar Ujala, Meerut, Uttar Pradesh - 250002
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-12 pt-6 border-t border-border text-center text-xs text-muted"
    >
      © {new Date().getFullYear()} Unique International. All rights reserved.
    </div>
  </div>
</footer>
